{
  "name": "leds",
  "version": "0.1.0",
  "private": true,
  "description": "LED Engineering & Design System",
  "workspaces": [
    "packages/*",
    "app"
  ],
  "scripts": {
    "build": "npm run build -w @leds/core && npm run build -w @leds/cli",
    "test": "npm run test -w @leds/core",
    "cli": "node packages/cli/dist/index.js",
    "dev": "npm run dev -w leds-app",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
